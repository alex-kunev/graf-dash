{
  "annotations": {"list": []},
  "description": "Per-service health summary with business metrics (orders, revenue, active users).",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "id": 1,
      "title": "Service Health",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "custom": {
            "align": "auto",
            "cellOptions": {"type": "color-background"},
            "inspect": false
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.01},
              {"color": "red", "value": 0.05}
            ]
          }
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "Service"},
            "properties": [
              {"id": "custom.width", "value": 160},
              {"id": "custom.cellOptions", "value": {"type": "auto"}}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "RPS"},
            "properties": [
              {"id": "unit", "value": "reqps"},
              {"id": "decimals", "value": 1},
              {"id": "custom.cellOptions", "value": {"type": "auto"}},
              {"id": "custom.width", "value": 100}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "Error Rate"},
            "properties": [
              {"id": "unit", "value": "percentunit"},
              {"id": "decimals", "value": 2},
              {"id": "custom.width", "value": 110}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "p50 Latency"},
            "properties": [
              {"id": "unit", "value": "s"},
              {"id": "decimals", "value": 3},
              {"id": "custom.cellOptions", "value": {"type": "auto"}},
              {"id": "custom.width", "value": 120}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "p99 Latency"},
            "properties": [
              {"id": "unit", "value": "s"},
              {"id": "decimals", "value": 3},
              {"id": "custom.cellOptions", "value": {"type": "auto"}},
              {"id": "custom.width", "value": 120}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "Active Connections"},
            "properties": [
              {"id": "unit", "value": "short"},
              {"id": "custom.cellOptions", "value": {"type": "auto"}},
              {"id": "custom.width", "value": 170}
            ]
          }
        ]
      },
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 1},
      "id": 2,
      "options": {
        "cellHeight": "sm",
        "footer": {"countRows": false, "fields": "", "reducer": ["sum"], "show": false},
        "showHeader": true,
        "sortBy": [{"desc": true, "displayName": "Error Rate"}]
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "editorMode": "code",
          "expr": "sum(rate(http_requests_total[$__rate_interval])) by (service)",
          "format": "table",
          "instant": true,
          "legendFormat": "__auto",
          "refId": "RPS"
        },
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "editorMode": "code",
          "expr": "sum(rate(http_requests_total{status_code=~\"5..\"}[$__rate_interval])) by (service) / sum(rate(http_requests_total[$__rate_interval])) by (service)",
          "format": "table",
          "instant": true,
          "legendFormat": "__auto",
          "refId": "ErrorRate"
        },
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "editorMode": "code",
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket[$__rate_interval])) by (le, service))",
          "format": "table",
          "instant": true,
          "legendFormat": "__auto",
          "refId": "P50"
        },
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "editorMode": "code",
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket[$__rate_interval])) by (le, service))",
          "format": "table",
          "instant": true,
          "legendFormat": "__auto",
          "refId": "P99"
        },
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "editorMode": "code",
          "expr": "active_connections",
          "format": "table",
          "instant": true,
          "legendFormat": "__auto",
          "refId": "Connections"
        }
      ],
      "title": "Service Health Table",
      "transformations": [
        {
          "id": "joinByField",
          "options": {"byField": "service", "mode": "outer"}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {"Time": true, "Time 1": true, "Time 2": true, "Time 3": true, "Time 4": true, "Time 5": true},
            "renameByName": {
              "service": "Service",
              "Value #RPS": "RPS",
              "Value #ErrorRate": "Error Rate",
              "Value #P50": "p50 Latency",
              "Value #P99": "p99 Latency",
              "Value #Connections": "Active Connections"
            }
          }
        }
      ],
      "type": "table"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 11},
      "id": 3,
      "title": "Business Metrics",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "blue", "value": null}
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 12},
      "id": 4,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "editorMode": "code",
          "expr": "active_users_total",
          "legendFormat": "Active Users",
          "range": false,
          "instant": true,
          "refId": "A"
        }
      ],
      "title": "Active Users",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null}
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 12},
      "id": 5,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "editorMode": "code",
          "expr": "increase(orders_total{status=\"completed\"}[1h])",
          "legendFormat": "Orders (1h)",
          "range": false,
          "instant": true,
          "refId": "A"
        }
      ],
      "title": "Orders (last 1h)",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
