# Copy to .env and customise before running
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=changeme

# Grafana Cloud remote_write credentials
# Get these from: Connections → Add new connection → Hosted Prometheus metrics
GRAFANA_REMOTE_WRITE_URL=https://prometheus-prod-XX.grafana.net/api/prom/push
GRAFANA_CLOUD_USERNAME=your_numeric_username
GRAFANA_CLOUD_TOKEN=your_token_here
